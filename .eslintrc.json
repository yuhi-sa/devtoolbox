{
  "env": {
    "browser": true,
    "es2021": true
  },
  "globals": {
    "DevToolBox": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": "warn",
    "no-redeclare": "warn",
    "eqeqeq": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error"
  }
}
